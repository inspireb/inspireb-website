---
import { Icon } from 'astro-icon/components';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const siteUrl = "https://www.inspireb.fr";
const currentUrl = canonical || siteUrl + Astro.url.pathname;
const ogImageUrl = ogImage ? siteUrl + ogImage : siteUrl + "/images/og-image.jpg";
import { services } from '../data/services.js';

const offers = services
  .filter(s => typeof s.schemaPrice === 'number')
  .map(s => ({
    "@type": "Offer",
    "itemOffered": { "@type": "Service", "name": s.categorie },
    "priceCurrency": "EUR",
    "price": String(s.schemaPrice),
    ...(s.schemaPrice === 0 ? { description: "Prix libre" } : {}),
  }));

const schema = {
  "@context": "https://schema.org",
  "@type": "HealthAndBeautyBusiness",
  "@id": siteUrl + "/#business",
  "name": "InspireB — Betty NOEL WOURMS",
  "description": "Praticienne bien-être et naturopathe à Sartilly-Baie-Bocage, entre Avranches et Granville. Massages, réflexologie plantaire, soins visage et naturopathie, dans une approche holistique et personnalisée.",
  "url": siteUrl,
  "telephone": "+33646712096",
  "priceRange": "€€",
  "image": ogImageUrl,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "2 Rue des Iris",
    "addressLocality": "Sartilly-Baie-Bocage",
    "postalCode": "50530",
    "addressRegion": "Normandie",
    "addressCountry": "FR",
  },
  "geo": { "@type": "GeoCoordinates", "latitude": "48.754920360832486", "longitude": "-1.4511759853949815" },
  "areaServed": [
    { "@type": "City", "name": "Sartilly-Baie-Bocage" },
    { "@type": "City", "name": "Granville" },
    { "@type": "City", "name": "Avranches" },
    { "@type": "City", "name": "Saint-Pair-sur-Mer" },
    { "@type": "City", "name": "Jullouville" },
    { "@type": "City", "name": "La Haye-Pesnel" },
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Monday", "opens": "09:30", "closes": "15:45" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "09:30", "closes": "15:45" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "09:30", "closes": "17:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "09:30", "closes": "15:45" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "09:00", "closes": "15:45" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "13:00" },
  ],
  "sameAs": [
    "https://www.instagram.com/betty_inspireb",
    "https://www.facebook.com/p/InspireB-Betty-NW-61574083089520/",
    "https://www.linkedin.com/in/betty-noel-wourms-43a2b9416",
    "https://www.resalib.fr/praticien/126051-inspireb-institut-de-beaute-sartilly-baie-bocage",
  ],
  "makesOffer": offers,
  // Note : pas d'aggregateRating ici. Google n'affiche pas d'étoiles pour les avis
  // qu'une entreprise publie sur son propre site (« self-serving »), et un tel balisage
  // peut entraîner une pénalité. Les avis et étoiles vivent sur la fiche Google Business.
};
---

