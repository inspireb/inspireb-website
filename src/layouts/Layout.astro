        <a href="/cgv" class="hover:text-white transition-colors underline underline-offset-2">CGV</a>
        <a href="#" class="js-cookie-settings hover:text-white transition-colors underline underline-offset-2">Gérer les cookies</a>
      </div>
    </footer>

    <!-- BOUTON FLOTTANT "PRENDRE RENDEZ-VOUS" (toujours visible, bas centre)
         La classe "js-setmore" ouvre la réservation dans une fenêtre par-dessus
         le site (popup) — on ne quitte jamais inspireb.fr.
         ⚠️ Remplacez l'URL par votre lien de réservation Setmore :
         Setmore → Apps & Integrations → Booking page → copier le lien -->
    <a id="floating-cta" href="https://inspireb.setmore.com/#services"
       class="js-setmore fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] bg-[#a8cbb7] text-white px-8 py-3.5 rounded-full text-sm font-semibold tracking-wide shadow-lg shadow-[#a8cbb7]/40 hover:bg-[#5a9480] hover:-translate-y-0.5 transition-all whitespace-nowrap">
      ✦ Prendre rendez-vous
