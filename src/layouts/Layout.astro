      <!-- Fenêtre -->
      <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-3xl h-[85vh] overflow-hidden flex flex-col">
        <div class="flex items-center justify-between px-5 py-3 border-b border-[#dde7e0]">
          <span class="font-dancing text-xl text-black">InspireB · Réservation</span>
          <button id="setmore-close" aria-label="Fermer"
                  class="text-[#4A4A4A]/60 hover:text-[#4A4A4A] text-2xl leading-none px-2 transition-colors">×</button>
        </div>
        <iframe id="setmore-iframe" src="about:blank" class="flex-1 w-full" frameborder="0" title="Réservation en ligne InspireB"></iframe>
      </div>
    </div>

    <script>
      // Popup Setmore : s'applique à TOUS les liens portant la classe js-setmore
      const modal = document.getElementById('setmore-modal');
      const iframe = document.getElementById('setmore-iframe') as HTMLIFrameElement | null;
      const closeBtn = document.getElementById('setmore-close');
      const overlay = document.getElementById('setmore-overlay');

      function openSetmore(url: string) {
        if (iframe) iframe.src = url;
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
      function closeSetmore() {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
        if (iframe) iframe.src = 'about:blank';
        document.body.style.overflow = '';
      }

      document.querySelectorAll('.js-setmore').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const url = btn.getAttribute('href');
          if (url) openSetmore(url);
        });
      });
      closeBtn?.addEventListener('click', closeSetmore);
      overlay?.addEventListener('click', closeSetmore);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeSetmore(); });
    </script>

    <!-- Script menu mobile -->
    <script>
      const toggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
    </script>

    <!-- BANDEAU COOKIES -->
    <div id="cookie-banner" class="hidden fixed bottom-0 left-0 right-0 z-[300] p-4 md:p-6">
      <div class="max-w-3xl mx-auto bg-white rounded-2xl shadow-2xl border border-[#dde7e0] p-6 md:flex md:items-center md:gap-6">
        <div class="flex-1 mb-4 md:mb-0">
          <p class="font-jakarta font-medium text-[#3D3D3D] mb-1">Votre confort de navigation</p>
          <p class="text-sm text-[#4A4A4A]/70 leading-relaxed">
            Ce site utilise des services externes (carte, vidéo, mesure d'audience) qui peuvent déposer des cookies.
            <a href="/politique-confidentialite" class="text-[#5a9480] underline underline-offset-2">En savoir plus</a>.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 flex-shrink-0">
          <button id="cookie-refuse" class="border-2 border-[#a8cbb7] text-[#5a9480] px-6 py-2.5 rounded-full text-sm font-medium hover:bg-[#eaf1ec] transition-colors">Refuser</button>
          <button id="cookie-accept" class="bg-[#a8cbb7] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-[#5a9480] transition-colors">Accepter</button>
        </div>
      </div>
    </div>

    <!-- Google Analytics 4 — chargé uniquement après consentement -->
    <script type="text/plain" data-cookie-script="https://www.googletagmanager.com/gtag/js?id=G-RF44C9KF0Z"></script>

    <script>
      // Google Consent Mode v2 — DOIT être déclaré avant tout, dès le chargement
      // de la page : indique à Google l'état par défaut (refusé) tant que la
      // cliente n'a pas répondu au bandeau. Sans ce signal, Google bloque
      // silencieusement l'envoi des données pour les visiteurs situés dans l'UE.
      (window as any).dataLayer = (window as any).dataLayer || [];
      const gtag = function () { (window as any).dataLayer.push(arguments); } as (...args: any[]) => void;
      (window as any).gtag = gtag;
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500,
      });

      function getConsent(): string | null {
        const m = document.cookie.match(/(?:^|;\s*)inspireb_consent=([^;]+)/);
        return m ? m[1] : null;
      }
      function setConsent(v: string) {
        // mémorisé 6 mois (la CNIL recommande de redemander périodiquement)
        document.cookie = `inspireb_consent=${v}; max-age=15768000; path=/; SameSite=Lax`;
      }
      function activerServicesTiers() {
        // Active tous les iframes mis en attente
        document.querySelectorAll('[data-cookie-src]').forEach(el => {
          const src = el.getAttribute('data-cookie-src');
          if (src) el.setAttribute('src', src);
          el.classList.remove('hidden');
          const embed = el.closest('[data-cookie-embed]');
          const ph = embed && embed.querySelector('[data-cookie-placeholder]');
          if (ph) ph.classList.add('hidden');
        });
        // Active les scripts mis en attente 
        document.querySelectorAll('script[type="text/plain"][data-cookie-script]').forEach(s => {
          const src = s.getAttribute('data-cookie-script');
          if (!src) return;
          const n = document.createElement('script');
          n.src = src;
          n.async = true; n.defer = true;
          document.head.appendChild(n);
        });

        // Signale à Google que la cliente a accepté la mesure d'audience
        gtag('consent', 'update', { analytics_storage: 'granted' });

        // Google Analytics 4 — initialisé uniquement après consentement
        if (!(window as any).gtagInitialized) {
          (window as any).gtagInitialized = true;
          gtag('js', new Date());
          gtag('config', 'G-RF44C9KF0Z');
        }
      }

      const banner = document.getElementById('cookie-banner');
      const consent = getConsent();
      if (consent === 'accepted') activerServicesTiers();
      else if (consent !== 'refused') banner?.classList.remove('hidden');

      document.getElementById('cookie-accept')?.addEventListener('click', () => {
        setConsent('accepted'); banner?.classList.add('hidden'); activerServicesTiers();
      });
      document.getElementById('cookie-refuse')?.addEventListener('click', () => {
        setConsent('refused'); banner?.classList.add('hidden');
      });
      // Rouvrir le choix depuis le footer
      document.querySelectorAll('.js-cookie-settings').forEach(b => {
        b.addEventListener('click', (e) => { e.preventDefault(); banner?.classList.remove('hidden'); });
      });
    </script>

    <script>
      const floatingCta = document.getElementById('floating-cta');
      // Cible automatiquement toutes les sections CTA au fond vert foncé (#5a9480)
      const ctaSections = document.querySelectorAll('section[class*="5a9480"]');

      if (floatingCta && ctaSections.length) {
        const visibles = new Set<Element>();
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) visibles.add(e.target);
            else visibles.delete(e.target);
          });
          if (visibles.size > 0) {
            // une section CTA est à l'écran → on masque le bouton flottant
            floatingCta.style.opacity = '0';
            floatingCta.style.pointerEvents = 'none';
            floatingCta.style.transform = 'translate(-50%, 24px)';
          } else {
            floatingCta.style.opacity = '1';
            floatingCta.style.pointerEvents = 'auto';
            floatingCta.style.transform = 'translate(-50%, 0)';
          }
        }, { threshold: 0.1 });

        ctaSections.forEach((s) => observer.observe(s));
      }
    </script>

  </body>
</html>