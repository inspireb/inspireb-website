---
import BlogPost from '../../layouts/BlogPost.astro';

// Génération statique de toutes les routes pour les articles.
// Le try/catch permet au site de se construire même quand il n'y a encore aucun
// article (dossier src/content/blog vide ou absent) : la page liste affiche alors
// son état « articles bientôt ». Dès que tu ajoutes des .md, les pages se créent seules.
export async function getStaticPaths() {
  let articles: import('astro').MarkdownInstance<Record<string, any>>[] = [];
  try {
    articles = await Astro.glob('../../../src/content/blog/*.md');
  } catch {
    articles = [];
  }
  return articles.map(article => {
    // Le slug = nom du fichier sans extension
    const slug = article.file.split('/').pop()?.replace('.md', '') || '';
    return {
      params: { slug },
      props: { article },
    };
  });
}

const { article } = Astro.props;
const { Content, frontmatter } = article;
const slug = Astro.params.slug;
---

<BlogPost
  title={frontmatter.title}
  description={frontmatter.description}
  date={frontmatter.date}
  category={frontmatter.category}
  coverImage={frontmatter.coverImage}
  slug={slug}
>
  <Content />
</BlogPost>